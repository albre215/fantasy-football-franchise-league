generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum LeagueRole {
  COMMISSIONER
  OWNER
}

enum SeasonStatus {
  PLANNING
  ACTIVE
  COMPLETED
  ARCHIVED
}

enum LeaguePhase {
  IN_SEASON
  POST_SEASON
  DROP_PHASE
  DRAFT_PHASE
}

enum SeasonDraftMode {
  CONTINUING_REPLACEMENT
  INAUGURAL_AUCTION
}

enum NFLConference {
  AFC
  NFC
}

enum DraftStatus {
  PLANNING
  ACTIVE
  PAUSED
  COMPLETED
  CANCELLED
}

enum IngestionProvider {
  MANUAL
  ESPN
  SLEEPER
  CSV
}

enum IngestionImportType {
  SEASON_STANDINGS
  WEEKLY_STANDINGS
}

enum IngestionRunStatus {
  RUNNING
  COMPLETED
  FAILED
}

enum LedgerEntryCategory {
  MANUAL_ADJUSTMENT
  FANTASY_PAYOUT
  NFL_REGULAR_SEASON
  NFL_PLAYOFF
  UNUSED_TEAM_ALLOCATION
}

enum NflResultProvider {
  MANUAL
  NFLVERSE
}

enum NflImportStatus {
  RUNNING
  COMPLETED
  FAILED
}

enum NflImportMode {
  FULL_SEASON
  SINGLE_WEEK
}

enum SeasonNflResultPhase {
  REGULAR_SEASON
  WILD_CARD
  DIVISIONAL
  CONFERENCE
  SUPER_BOWL
}

enum SeasonNflGameResult {
  WIN
  LOSS
  TIE
}

model User {
  id                  String                  @id @default(cuid())
  email               String                  @unique
  displayName         String
  phoneNumber         String?
  profileImageUrl     String?
  passwordHash        String?
  createdAt           DateTime                @default(now())
  updatedAt           DateTime                @updatedAt
  leagueMembers       LeagueMember[]
  passwordResetTokens PasswordResetToken[]
  temporaryLoginCodes TemporaryLoginCode[]
}

model PasswordResetToken {
  id         String   @id @default(cuid())
  userId     String
  tokenHash  String   @unique
  expiresAt  DateTime
  consumedAt DateTime?
  createdAt  DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, expiresAt])
}

model TemporaryLoginCode {
  id                  String   @id @default(cuid())
  userId              String
  codeHash            String
  phoneNumberSnapshot String
  attemptCount        Int      @default(0)
  lastAttemptAt       DateTime?
  lockedUntil         DateTime?
  expiresAt           DateTime
  consumedAt          DateTime?
  createdAt           DateTime @default(now())
  user                User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, expiresAt])
  @@index([id, expiresAt])
}

model League {
  id            String              @id @default(cuid())
  leagueCode    String?             @unique
  name          String
  slug          String              @unique
  description   String?
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt
  members       LeagueMember[]
  seasons       Season[]
  drafts        Draft[]
  inauguralAuctions InauguralAuction[]
  ledgerEntries LedgerEntry[]
}

model LeagueMember {
  id                String               @id @default(cuid())
  leagueId          String
  userId            String
  role              LeagueRole           @default(OWNER)
  joinedAt          DateTime             @default(now())
  createdAt         DateTime             @default(now())
  updatedAt         DateTime             @updatedAt
  league            League               @relation(fields: [leagueId], references: [id], onDelete: Cascade)
  user              User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  teamOwnerships    TeamOwnership[]
  draftPicks        DraftPick[]
  keeperSelections KeeperSelection[]
  seasonStandings  SeasonStanding[]
  weeklyStandings  WeeklyStanding[]
  sourceMappings   SeasonMemberSourceMapping[]
  ledgerEntries    LedgerEntry[]
  nflTeamResults   SeasonNflTeamResult[]
  inauguralAuctionBids InauguralAuctionBid[]
  inauguralAuctionAwards InauguralAuctionAward[]
  inauguralAuctionPresences InauguralAuctionPresence[]

  @@unique([leagueId, userId])
  @@index([userId])
}

model Season {
  id                String               @id @default(cuid())
  leagueId          String
  year              Int
  name              String?
  fantasyPayoutConfig Json?
  status            SeasonStatus         @default(PLANNING)
  leaguePhase       LeaguePhase          @default(IN_SEASON)
  draftMode         SeasonDraftMode      @default(CONTINUING_REPLACEMENT)
  isLocked          Boolean              @default(false)
  startsAt          DateTime?
  endsAt            DateTime?
  createdAt         DateTime             @default(now())
  updatedAt         DateTime             @updatedAt
  league            League               @relation(fields: [leagueId], references: [id], onDelete: Cascade)
  teamOwnerships    TeamOwnership[]
  targetDraft       Draft?               @relation("TargetSeasonDraft")
  sourceDrafts      Draft[]              @relation("SourceSeasonDraft")
  keeperSelections KeeperSelection[] @relation("KeeperSourceSeason")
  sourceConfigs     SeasonSourceConfig[]
  ingestionRuns     IngestionRun[]
  seasonStandings SeasonStanding[]
  weeklyStandings WeeklyStanding[]
  ledgerEntries    LedgerEntry[]
  nflImportRuns    SeasonNflImportRun[]
  nflTeamResults   SeasonNflTeamResult[]
  inauguralAuction InauguralAuction?
  draftSchedule    DraftSchedule?

  @@unique([leagueId, year])
  @@index([leagueId, status])
}

model DraftSchedule {
  id          String    @id @default(cuid())
  seasonId    String    @unique
  draftType   DraftType
  scheduledAt DateTime
  timezone    String
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  season      Season    @relation(fields: [seasonId], references: [id], onDelete: Cascade)

  @@index([scheduledAt])
}

enum DraftType {
  INAUGURAL
  KEEPER
  OFFSEASON
}

model TeamOwnership {
  id             String       @id @default(cuid())
  seasonId       String
  leagueMemberId String
  nflTeamId      String
  slot           Int
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  season         Season       @relation(fields: [seasonId], references: [id], onDelete: Cascade)
  leagueMember   LeagueMember @relation(fields: [leagueMemberId], references: [id], onDelete: Cascade)
  nflTeam        NFLTeam      @relation(fields: [nflTeamId], references: [id], onDelete: Restrict)

  @@unique([seasonId, leagueMemberId, slot])
  @@unique([seasonId, nflTeamId])
  @@index([leagueMemberId])
  @@index([nflTeamId])
}

model NFLTeam {
  id               String                @id @default(cuid())
  name             String
  abbreviation     String                @unique
  conference       NFLConference
  division         String
  isActive         Boolean               @default(true)
  createdAt        DateTime              @default(now())
  updatedAt        DateTime              @updatedAt
  teamOwnerships   TeamOwnership[]
  draftPicks       DraftPick[]
  keeperSelections KeeperSelection[]
  inauguralAuctionNominations InauguralAuctionNomination[]
  seasonResults    SeasonNflTeamResult[] @relation("SeasonNflTeam")
  opponentResults  SeasonNflTeamResult[] @relation("SeasonNflOpponentTeam")
}

model Draft {
  id              String            @id @default(cuid())
  leagueId        String
  targetSeasonId  String            @unique
  sourceSeasonId  String
  status          DraftStatus       @default(PLANNING)
  currentPick     Int               @default(1)
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  completedAt     DateTime?
  league          League            @relation(fields: [leagueId], references: [id], onDelete: Cascade)
  targetSeason    Season            @relation("TargetSeasonDraft", fields: [targetSeasonId], references: [id], onDelete: Cascade)
  sourceSeason    Season            @relation("SourceSeasonDraft", fields: [sourceSeasonId], references: [id], onDelete: Restrict)
  picks           DraftPick[]
  keeperSelections KeeperSelection[]

  @@index([leagueId, status])
}

model InauguralAuction {
  id                  String                        @id @default(cuid())
  leagueId            String
  seasonId            String                        @unique
  status              DraftStatus                   @default(PLANNING)
  orderMethod         InauguralAuctionOrderMethod
  currentNominationIndex Int                        @default(0)
  clockStartedAt      DateTime?
  clockExpiresAt      DateTime?
  pausedRemainingMs   Int?
  announcementAwardId String?
  announcementEndsAt  DateTime?
  completedAt         DateTime?
  createdAt           DateTime                      @default(now())
  updatedAt           DateTime                      @updatedAt
  league              League                        @relation(fields: [leagueId], references: [id], onDelete: Cascade)
  season              Season                        @relation(fields: [seasonId], references: [id], onDelete: Cascade)
  nominationEntries   InauguralAuctionNomination[]
  bids                InauguralAuctionBid[]
  awards              InauguralAuctionAward[]
  presences           InauguralAuctionPresence[]

  @@index([leagueId, status])
}

model InauguralAuctionPresence {
  id             String           @id @default(cuid())
  auctionId      String
  leagueMemberId String
  joinedAt       DateTime         @default(now())
  lastSeenAt     DateTime         @default(now())
  auction        InauguralAuction @relation(fields: [auctionId], references: [id], onDelete: Cascade)
  leagueMember   LeagueMember     @relation(fields: [leagueMemberId], references: [id], onDelete: Cascade)

  @@unique([auctionId, leagueMemberId])
  @@index([leagueMemberId])
}

enum InauguralAuctionOrderMethod {
  ALPHABETICAL
  DIVISION
  PREVIOUS_YEAR_RECORD
  CUSTOM
}

enum AuctionAwardSource {
  BID
  AUTO_ASSIGN
  SIMULATED
  FINAL_SELECTION
}

model InauguralAuctionNomination {
  id         String            @id @default(cuid())
  auctionId   String
  nflTeamId   String
  orderIndex  Int
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
  auction     InauguralAuction  @relation(fields: [auctionId], references: [id], onDelete: Cascade)
  nflTeam     NFLTeam           @relation(fields: [nflTeamId], references: [id], onDelete: Restrict)
  bids        InauguralAuctionBid[]
  award       InauguralAuctionAward?

  @@unique([auctionId, orderIndex])
  @@unique([auctionId, nflTeamId])
  @@index([nflTeamId])
}

model InauguralAuctionBid {
  id           String                     @id @default(cuid())
  auctionId     String
  nominationId  String
  leagueMemberId String
  amount        Int
  createdAt     DateTime                   @default(now())
  updatedAt     DateTime                   @updatedAt
  auction       InauguralAuction           @relation(fields: [auctionId], references: [id], onDelete: Cascade)
  nomination    InauguralAuctionNomination @relation(fields: [nominationId], references: [id], onDelete: Cascade)
  leagueMember  LeagueMember               @relation(fields: [leagueMemberId], references: [id], onDelete: Restrict)

  @@index([auctionId, nominationId, amount])
  @@index([leagueMemberId])
}

model InauguralAuctionAward {
  id             String                     @id @default(cuid())
  auctionId      String
  nominationId   String                     @unique
  leagueMemberId String
  amount         Int
  source         AuctionAwardSource         @default(BID)
  awardedAt      DateTime                   @default(now())
  createdAt      DateTime                   @default(now())
  updatedAt      DateTime                   @updatedAt
  auction        InauguralAuction           @relation(fields: [auctionId], references: [id], onDelete: Cascade)
  nomination     InauguralAuctionNomination @relation(fields: [nominationId], references: [id], onDelete: Cascade)
  leagueMember   LeagueMember               @relation(fields: [leagueMemberId], references: [id], onDelete: Restrict)

  @@index([auctionId, awardedAt])
  @@index([leagueMemberId])
}

model DraftPick {
  id                    String        @id @default(cuid())
  draftId               String
  overallPickNumber     Int
  roundNumber           Int
  roundPickNumber       Int
  selectingLeagueMemberId String
  selectedNflTeamId     String?
  actingUserId          String?
  pickedAt              DateTime?
  createdAt             DateTime      @default(now())
  updatedAt             DateTime      @updatedAt
  draft                 Draft         @relation(fields: [draftId], references: [id], onDelete: Cascade)
  selectingLeagueMember LeagueMember  @relation(fields: [selectingLeagueMemberId], references: [id], onDelete: Restrict)
  selectedNflTeam       NFLTeam?      @relation(fields: [selectedNflTeamId], references: [id], onDelete: Restrict)

  @@unique([draftId, overallPickNumber])
  @@unique([draftId, selectedNflTeamId])
  @@index([selectingLeagueMemberId])
}

model KeeperSelection {
  id              String        @id @default(cuid())
  draftId         String
  leagueMemberId  String
  nflTeamId       String
  sourceSeasonId  String
  actingUserId    String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  draft           Draft         @relation(fields: [draftId], references: [id], onDelete: Cascade)
  leagueMember    LeagueMember  @relation(fields: [leagueMemberId], references: [id], onDelete: Restrict)
  nflTeam         NFLTeam       @relation(fields: [nflTeamId], references: [id], onDelete: Restrict)
  sourceSeason    Season        @relation("KeeperSourceSeason", fields: [sourceSeasonId], references: [id], onDelete: Restrict)

  @@unique([draftId, leagueMemberId, nflTeamId])
  @@index([leagueMemberId])
  @@index([nflTeamId])
}

model SeasonSourceConfig {
  id                String                      @id @default(cuid())
  seasonId          String
  provider          IngestionProvider
  externalLeagueId  String?
  externalSeasonKey String?
  config            Json
  createdAt         DateTime                    @default(now())
  updatedAt         DateTime                    @updatedAt
  season            Season                      @relation(fields: [seasonId], references: [id], onDelete: Cascade)
  mappings          SeasonMemberSourceMapping[]
  ingestionRuns     IngestionRun[]
  seasonStandings   SeasonStanding[]
  weeklyStandings   WeeklyStanding[]

  @@unique([seasonId, provider])
  @@index([seasonId])
}

model SeasonMemberSourceMapping {
  id                   String             @id @default(cuid())
  seasonSourceConfigId String
  leagueMemberId       String
  externalEntityId     String
  externalDisplayName  String
  confidence           Int?
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt
  seasonSourceConfig   SeasonSourceConfig @relation(fields: [seasonSourceConfigId], references: [id], onDelete: Cascade)
  leagueMember         LeagueMember       @relation(fields: [leagueMemberId], references: [id], onDelete: Cascade)

  @@unique([seasonSourceConfigId, leagueMemberId])
  @@unique([seasonSourceConfigId, externalEntityId])
  @@index([leagueMemberId])
}

model IngestionRun {
  id                   String               @id @default(cuid())
  seasonId             String
  seasonSourceConfigId String?
  provider             IngestionProvider
  importType           IngestionImportType
  status               IngestionRunStatus   @default(RUNNING)
  weekNumber           Int?
  actingUserId         String?
  startedAt            DateTime             @default(now())
  completedAt          DateTime?
  sourceSummary        Json?
  warnings             Json?
  errorMessage         String?
  createdAt            DateTime             @default(now())
  updatedAt            DateTime             @updatedAt
  season               Season               @relation(fields: [seasonId], references: [id], onDelete: Cascade)
  seasonSourceConfig   SeasonSourceConfig?  @relation(fields: [seasonSourceConfigId], references: [id], onDelete: SetNull)
  seasonStandings      SeasonStanding[]
  weeklyStandings      WeeklyStanding[]

  @@index([seasonId, provider, importType])
}

model SeasonStanding {
  id                   String               @id @default(cuid())
  seasonId             String
  leagueMemberId       String
  provider             IngestionProvider
  seasonSourceConfigId String?
  ingestionRunId       String?
  externalEntityId     String?
  externalDisplayName  String?
  rank                 Int?
  wins                 Int?
  losses               Int?
  ties                 Int?
  pointsFor            Float?
  pointsAgainst        Float?
  playoffFinish        String?
  isChampion           Boolean?
  metadata             Json?
  createdAt            DateTime             @default(now())
  updatedAt            DateTime             @updatedAt
  season               Season               @relation(fields: [seasonId], references: [id], onDelete: Cascade)
  leagueMember         LeagueMember         @relation(fields: [leagueMemberId], references: [id], onDelete: Cascade)
  seasonSourceConfig   SeasonSourceConfig?  @relation(fields: [seasonSourceConfigId], references: [id], onDelete: SetNull)
  ingestionRun         IngestionRun?        @relation(fields: [ingestionRunId], references: [id], onDelete: SetNull)

  @@unique([seasonId, leagueMemberId])
  @@index([seasonId, rank])
}

model WeeklyStanding {
  id                   String               @id @default(cuid())
  seasonId             String
  weekNumber           Int
  leagueMemberId       String
  provider             IngestionProvider
  seasonSourceConfigId String?
  ingestionRunId       String?
  externalEntityId     String?
  externalDisplayName  String?
  rank                 Int?
  pointsFor            Float?
  pointsAgainst        Float?
  result               String?
  opponentExternalEntityId String?
  opponentDisplayName  String?
  metadata             Json?
  createdAt            DateTime             @default(now())
  updatedAt            DateTime             @updatedAt
  season               Season               @relation(fields: [seasonId], references: [id], onDelete: Cascade)
  leagueMember         LeagueMember         @relation(fields: [leagueMemberId], references: [id], onDelete: Cascade)
  seasonSourceConfig   SeasonSourceConfig?  @relation(fields: [seasonSourceConfigId], references: [id], onDelete: SetNull)
  ingestionRun         IngestionRun?        @relation(fields: [ingestionRunId], references: [id], onDelete: SetNull)

  @@unique([seasonId, weekNumber, leagueMemberId])
  @@index([seasonId, weekNumber, rank])
}

model LedgerEntry {
  id             String              @id @default(cuid())
  leagueId       String
  seasonId       String
  leagueMemberId String
  category       LedgerEntryCategory
  amount         Decimal             @db.Decimal(12, 2)
  description    String
  metadata       Json?
  actingUserId   String?
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt
  league         League              @relation(fields: [leagueId], references: [id], onDelete: Cascade)
  season         Season              @relation(fields: [seasonId], references: [id], onDelete: Cascade)
  leagueMember   LeagueMember        @relation(fields: [leagueMemberId], references: [id], onDelete: Cascade)

  @@index([leagueId, createdAt])
  @@index([seasonId, createdAt])
  @@index([seasonId, leagueMemberId, createdAt])
  @@index([seasonId, category])
}

model SeasonNflImportRun {
  id                String            @id @default(cuid())
  seasonId          String
  seasonYear        Int
  concurrencyKey    String?           @unique
  provider          NflResultProvider
  mode              NflImportMode
  weekNumber        Int?
  status            NflImportStatus   @default(RUNNING)
  actingUserId      String?
  importedResultCount Int             @default(0)
  warnings          Json?
  errorMessage      String?
  startedAt         DateTime          @default(now())
  completedAt       DateTime?
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt
  season            Season            @relation(fields: [seasonId], references: [id], onDelete: Cascade)
  results           SeasonNflTeamResult[]

  @@index([seasonId, startedAt])
  @@index([seasonId, provider, mode, weekNumber])
}

model SeasonNflTeamResult {
  id                String               @id @default(cuid())
  seasonId          String
  seasonYear        Int
  weekNumber        Int
  phase             SeasonNflResultPhase
  nflTeamId         String
  opponentNflTeamId String?
  leagueMemberId    String?
  result            SeasonNflGameResult
  pointsFor         Int?
  pointsAgainst     Int?
  sourceProvider    NflResultProvider
  importRunId       String?
  actingUserId      String?
  metadata          Json?
  createdAt         DateTime             @default(now())
  updatedAt         DateTime             @updatedAt
  season            Season               @relation(fields: [seasonId], references: [id], onDelete: Cascade)
  nflTeam           NFLTeam              @relation("SeasonNflTeam", fields: [nflTeamId], references: [id], onDelete: Restrict)
  opponentNflTeam   NFLTeam?             @relation("SeasonNflOpponentTeam", fields: [opponentNflTeamId], references: [id], onDelete: SetNull)
  leagueMember      LeagueMember?        @relation(fields: [leagueMemberId], references: [id], onDelete: SetNull)
  importRun         SeasonNflImportRun?  @relation(fields: [importRunId], references: [id], onDelete: SetNull)

  @@unique([seasonId, weekNumber, phase, nflTeamId])
  @@index([seasonId, weekNumber])
  @@index([seasonId, leagueMemberId])
  @@index([seasonId, phase])
  @@index([seasonId, nflTeamId])
}
