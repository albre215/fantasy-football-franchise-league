generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum LeagueRole {
  COMMISSIONER
  OWNER
}

enum SeasonStatus {
  PLANNING
  ACTIVE
  COMPLETED
  ARCHIVED
}

enum NFLConference {
  AFC
  NFC
}

enum DraftStatus {
  PLANNING
  ACTIVE
  PAUSED
  COMPLETED
  CANCELLED
}

enum IngestionProvider {
  MANUAL
  ESPN
  SLEEPER
  CSV
}

enum IngestionImportType {
  SEASON_STANDINGS
  WEEKLY_STANDINGS
}

enum IngestionRunStatus {
  RUNNING
  COMPLETED
  FAILED
}

model User {
  id            String         @id @default(cuid())
  email         String         @unique
  displayName   String
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  leagueMembers LeagueMember[]
}

model League {
  id          String         @id @default(cuid())
  name        String
  slug        String         @unique
  description String?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  members     LeagueMember[]
  seasons     Season[]
  drafts      Draft[]
}

model LeagueMember {
  id             String          @id @default(cuid())
  leagueId       String
  userId         String
  role           LeagueRole      @default(OWNER)
  joinedAt       DateTime        @default(now())
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  league         League          @relation(fields: [leagueId], references: [id], onDelete: Cascade)
  user           User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  teamOwnerships TeamOwnership[]
  draftPicks     DraftPick[]
  keeperSelections KeeperSelection[]
  seasonStandings SeasonStanding[]
  weeklyStandings WeeklyStanding[]
  sourceMappings SeasonMemberSourceMapping[]

  @@unique([leagueId, userId])
  @@index([userId])
}

model Season {
  id             String          @id @default(cuid())
  leagueId       String
  year           Int
  name           String?
  status         SeasonStatus    @default(PLANNING)
  isLocked       Boolean         @default(false)
  startsAt       DateTime?
  endsAt         DateTime?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  league         League          @relation(fields: [leagueId], references: [id], onDelete: Cascade)
  teamOwnerships TeamOwnership[]
  targetDraft    Draft?          @relation("TargetSeasonDraft")
  sourceDrafts   Draft[]         @relation("SourceSeasonDraft")
  keeperSelections KeeperSelection[] @relation("KeeperSourceSeason")
  sourceConfigs  SeasonSourceConfig[]
  ingestionRuns  IngestionRun[]
  seasonStandings SeasonStanding[]
  weeklyStandings WeeklyStanding[]

  @@unique([leagueId, year])
  @@index([leagueId, status])
}

model TeamOwnership {
  id             String       @id @default(cuid())
  seasonId       String
  leagueMemberId String
  nflTeamId      String
  slot           Int
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  season         Season       @relation(fields: [seasonId], references: [id], onDelete: Cascade)
  leagueMember   LeagueMember @relation(fields: [leagueMemberId], references: [id], onDelete: Cascade)
  nflTeam        NFLTeam      @relation(fields: [nflTeamId], references: [id], onDelete: Restrict)

  @@unique([seasonId, leagueMemberId, slot])
  @@unique([seasonId, nflTeamId])
  @@index([leagueMemberId])
  @@index([nflTeamId])
}

model NFLTeam {
  id             String          @id @default(cuid())
  name           String
  abbreviation   String          @unique
  conference     NFLConference
  division       String
  isActive       Boolean         @default(true)
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  teamOwnerships TeamOwnership[]
  draftPicks     DraftPick[]
  keeperSelections KeeperSelection[]
}

model Draft {
  id              String            @id @default(cuid())
  leagueId        String
  targetSeasonId  String            @unique
  sourceSeasonId  String
  status          DraftStatus       @default(PLANNING)
  currentPick     Int               @default(1)
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  completedAt     DateTime?
  league          League            @relation(fields: [leagueId], references: [id], onDelete: Cascade)
  targetSeason    Season            @relation("TargetSeasonDraft", fields: [targetSeasonId], references: [id], onDelete: Cascade)
  sourceSeason    Season            @relation("SourceSeasonDraft", fields: [sourceSeasonId], references: [id], onDelete: Restrict)
  picks           DraftPick[]
  keeperSelections KeeperSelection[]

  @@index([leagueId, status])
}

model DraftPick {
  id                    String        @id @default(cuid())
  draftId               String
  overallPickNumber     Int
  roundNumber           Int
  roundPickNumber       Int
  selectingLeagueMemberId String
  selectedNflTeamId     String?
  actingUserId          String?
  pickedAt              DateTime?
  createdAt             DateTime      @default(now())
  updatedAt             DateTime      @updatedAt
  draft                 Draft         @relation(fields: [draftId], references: [id], onDelete: Cascade)
  selectingLeagueMember LeagueMember  @relation(fields: [selectingLeagueMemberId], references: [id], onDelete: Restrict)
  selectedNflTeam       NFLTeam?      @relation(fields: [selectedNflTeamId], references: [id], onDelete: Restrict)

  @@unique([draftId, overallPickNumber])
  @@unique([draftId, selectedNflTeamId])
  @@index([selectingLeagueMemberId])
}

model KeeperSelection {
  id              String        @id @default(cuid())
  draftId         String
  leagueMemberId  String
  nflTeamId       String
  sourceSeasonId  String
  actingUserId    String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  draft           Draft         @relation(fields: [draftId], references: [id], onDelete: Cascade)
  leagueMember    LeagueMember  @relation(fields: [leagueMemberId], references: [id], onDelete: Restrict)
  nflTeam         NFLTeam       @relation(fields: [nflTeamId], references: [id], onDelete: Restrict)
  sourceSeason    Season        @relation("KeeperSourceSeason", fields: [sourceSeasonId], references: [id], onDelete: Restrict)

  @@unique([draftId, leagueMemberId, nflTeamId])
  @@index([leagueMemberId])
  @@index([nflTeamId])
}

model SeasonSourceConfig {
  id                String                      @id @default(cuid())
  seasonId          String
  provider          IngestionProvider
  externalLeagueId  String?
  externalSeasonKey String?
  config            Json
  createdAt         DateTime                    @default(now())
  updatedAt         DateTime                    @updatedAt
  season            Season                      @relation(fields: [seasonId], references: [id], onDelete: Cascade)
  mappings          SeasonMemberSourceMapping[]
  ingestionRuns     IngestionRun[]
  seasonStandings   SeasonStanding[]
  weeklyStandings   WeeklyStanding[]

  @@unique([seasonId, provider])
  @@index([seasonId])
}

model SeasonMemberSourceMapping {
  id                   String             @id @default(cuid())
  seasonSourceConfigId String
  leagueMemberId       String
  externalEntityId     String
  externalDisplayName  String
  confidence           Int?
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt
  seasonSourceConfig   SeasonSourceConfig @relation(fields: [seasonSourceConfigId], references: [id], onDelete: Cascade)
  leagueMember         LeagueMember       @relation(fields: [leagueMemberId], references: [id], onDelete: Cascade)

  @@unique([seasonSourceConfigId, leagueMemberId])
  @@unique([seasonSourceConfigId, externalEntityId])
  @@index([leagueMemberId])
}

model IngestionRun {
  id                   String               @id @default(cuid())
  seasonId             String
  seasonSourceConfigId String?
  provider             IngestionProvider
  importType           IngestionImportType
  status               IngestionRunStatus   @default(RUNNING)
  weekNumber           Int?
  actingUserId         String?
  startedAt            DateTime             @default(now())
  completedAt          DateTime?
  sourceSummary        Json?
  warnings             Json?
  errorMessage         String?
  createdAt            DateTime             @default(now())
  updatedAt            DateTime             @updatedAt
  season               Season               @relation(fields: [seasonId], references: [id], onDelete: Cascade)
  seasonSourceConfig   SeasonSourceConfig?  @relation(fields: [seasonSourceConfigId], references: [id], onDelete: SetNull)
  seasonStandings      SeasonStanding[]
  weeklyStandings      WeeklyStanding[]

  @@index([seasonId, provider, importType])
}

model SeasonStanding {
  id                   String               @id @default(cuid())
  seasonId             String
  leagueMemberId       String
  provider             IngestionProvider
  seasonSourceConfigId String?
  ingestionRunId       String?
  externalEntityId     String?
  externalDisplayName  String?
  rank                 Int?
  wins                 Int?
  losses               Int?
  ties                 Int?
  pointsFor            Float?
  pointsAgainst        Float?
  playoffFinish        String?
  isChampion           Boolean?
  metadata             Json?
  createdAt            DateTime             @default(now())
  updatedAt            DateTime             @updatedAt
  season               Season               @relation(fields: [seasonId], references: [id], onDelete: Cascade)
  leagueMember         LeagueMember         @relation(fields: [leagueMemberId], references: [id], onDelete: Cascade)
  seasonSourceConfig   SeasonSourceConfig?  @relation(fields: [seasonSourceConfigId], references: [id], onDelete: SetNull)
  ingestionRun         IngestionRun?        @relation(fields: [ingestionRunId], references: [id], onDelete: SetNull)

  @@unique([seasonId, leagueMemberId])
  @@index([seasonId, rank])
}

model WeeklyStanding {
  id                   String               @id @default(cuid())
  seasonId             String
  weekNumber           Int
  leagueMemberId       String
  provider             IngestionProvider
  seasonSourceConfigId String?
  ingestionRunId       String?
  externalEntityId     String?
  externalDisplayName  String?
  rank                 Int?
  pointsFor            Float?
  pointsAgainst        Float?
  result               String?
  opponentExternalEntityId String?
  opponentDisplayName  String?
  metadata             Json?
  createdAt            DateTime             @default(now())
  updatedAt            DateTime             @updatedAt
  season               Season               @relation(fields: [seasonId], references: [id], onDelete: Cascade)
  leagueMember         LeagueMember         @relation(fields: [leagueMemberId], references: [id], onDelete: Cascade)
  seasonSourceConfig   SeasonSourceConfig?  @relation(fields: [seasonSourceConfigId], references: [id], onDelete: SetNull)
  ingestionRun         IngestionRun?        @relation(fields: [ingestionRunId], references: [id], onDelete: SetNull)

  @@unique([seasonId, weekNumber, leagueMemberId])
  @@index([seasonId, weekNumber, rank])
}
